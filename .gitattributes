# Default: text files use LF (Unix) line endings everywhere, including Windows checkouts.
* text=auto eol=lf

# Source / config
*.sh        text eol=lf
*.tmux      text eol=lf
*.md        text eol=lf
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.conf      text eol=lf
*.service   text eol=lf
Makefile    text eol=lf

# Binary assets — never line-end convert, never diff as text
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.svg       binary
*.pdf       binary
*.zip       binary
*.tar.gz    binary
